# Application
PORT=3000
# DATA_DIR utilisé uniquement si DATABASE_URL n'est pas défini
DATA_DIR=./data
DATABASE_URL=file:/app/data/app.db

# Security (NE PAS committer de vraies valeurs)
JWT_SECRET=change_me_jwt_secret
ENCRYPTION_KEY=change_me_32_characters_exact_key

# Bootstrap admin user
ADMIN_USER=admin
ADMIN_PASS=admin_change_me
